# ===== OKX API (必填 - 自动交易用) =====
# 在 https://www.okx.com/account/my-api 创建，权限选"交易"
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# ===== GitHub Token (必填 - Bounty扫描用) =====
# 在 https://github.com/settings/tokens 创建，权限选 public_repo
GITHUB_TOKEN=ghp_your_token_here

# ===== AgentHansa Token (可选 - AI任务签到用) =====
# 注册 https://www.agenthansa.com 后获取
AH_TOKEN=your_agenthansa_token_here
AH_WALLET=your_wallet_address_here

# ===== 代理配置 (可选 - 如果服务器需要代理访问API) ====
PROXY_URL=http://127.0.0.1:7890

# ===== 交易配置 (可选 - 可自定义) =====
MAX_POSITIONS=2
PER_TRADE_RISK_PCT=2.0
STOP_LOSS_PCT=5.0
MAX_DRAWDOWN_PCT=10.0
